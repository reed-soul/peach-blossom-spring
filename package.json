{
  "name": "peach-blossom-spring",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run narrative:build && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "narrative:build": "node scripts/build-narrative.mjs",
    "texture:peach": "node scripts/texture/dilate-alpha.mjs public/textures/peach/peach_blossom.png --passes 16 && node scripts/texture/derive-pbr.mjs public/textures/peach/peach_blossom.png --strength 2.0 && node scripts/texture/derive-translucency.mjs public/textures/peach/peach_blossom.png"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "inkjs": "^2.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simplex-noise": "^4.0.3",
    "three": "0.184.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.184.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
